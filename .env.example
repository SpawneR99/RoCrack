# ============================================================
#  RoCrack .env  —  COPY THIS FILE TO .env AND FILL IN VALUES
#  NEVER COMMIT .env TO GIT.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=production
# Set to "true" when you're behind Cloudflare / Coolify's reverse proxy so real IPs are read from X-Forwarded-For
TRUST_PROXY=true

# --- Data directories (persisted via Coolify volume mounts) ---
DATA_DIR=./data
UPLOADS_DIR=./uploads

# --- Admin ---
# Admin panel is hardcoded to /admin. Username below is not secret but shouldn't be guessable.
ADMIN_USERNAME=admin
# bcrypt hash of the admin password. GENERATE WITH:  npm run hash -- "YourStrongPassword"
# Example (this is "changeme" hashed — DO NOT USE IN PRODUCTION):
ADMIN_PASSWORD_HASH=$2a$12$replace.this.with.your.own.bcrypt.hash.value.here.0000000000000

# --- Crypto secrets (generate long random strings, 64+ chars each) ---
# You can generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_64_char_hex_string_for_jwt_signing_only
CSRF_SECRET=replace_me_with_another_long_random_64_char_hex_string_for_csrf_tokens
COOKIE_SECRET=replace_me_with_yet_another_long_random_64_char_hex_string_for_cookies

# Session lifetime in seconds (default 8h)
SESSION_TTL=28800

# --- AdBlueMedia (button flow) ---
# Landing URL that users are sent to when AdBlueMedia is the active provider.
# The script's niche is appended automatically as ?s1=<niche>.
ADBLUE_BUTTON_URL=https://devicegetty.com/3211251

# --- OGAds (button flow) ---
# Landing URL that users are sent to when OGAds is the active provider.
# The script's niche is appended automatically as ?aff_sub4=<niche>.
OGADS_BUTTON_URL=https://devicevrfy.net/cl/i/7jvwdk

# --- Legacy / unused ---
# The offer-list API is no longer used by the site (both providers run the
# one-click button flow now). These three variables are kept for reference
# only and can be left empty in production.
ADBLUE_USER_ID=
ADBLUE_API_KEY=
ADBLUE_ENDPOINT=
OGADS_API_KEY=
OGADS_ENDPOINT=

# NOTE: Active provider (adbluemedia | ogads) is selected from the admin
# UI → Settings. Nothing offer-related needs to live in env beyond the two
# *_BUTTON_URL values above.
