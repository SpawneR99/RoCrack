# ============================================================
#  RoCrack .env  —  COPY THIS FILE TO .env AND FILL IN VALUES
#  NEVER COMMIT .env TO GIT.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=production
# Set to "true" when you're behind Cloudflare / Coolify's reverse proxy so real IPs are read from X-Forwarded-For
TRUST_PROXY=true

# --- Data directories (persisted via Coolify volume mounts) ---
DATA_DIR=./data
UPLOADS_DIR=./uploads

# --- Admin ---
# Admin panel is hardcoded to /admin. Username below is not secret but shouldn't be guessable.
ADMIN_USERNAME=admin
# bcrypt hash of the admin password. GENERATE WITH:  npm run hash -- "YourStrongPassword"
# Example (this is "changeme" hashed — DO NOT USE IN PRODUCTION):
ADMIN_PASSWORD_HASH=$2a$12$replace.this.with.your.own.bcrypt.hash.value.here.0000000000000

# --- Crypto secrets (generate long random strings, 64+ chars each) ---
# You can generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_64_char_hex_string_for_jwt_signing_only
CSRF_SECRET=replace_me_with_another_long_random_64_char_hex_string_for_csrf_tokens
COOKIE_SECRET=replace_me_with_yet_another_long_random_64_char_hex_string_for_cookies

# Session lifetime in seconds (default 8h)
SESSION_TTL=28800

# --- AdBlueMedia ---
ADBLUE_USER_ID=47937
ADBLUE_API_KEY=aae3663b2d691169b7643a13f62685f5
ADBLUE_ENDPOINT=https://d1y3y09sav47f5.cloudfront.net/public/offers/feed.php

# --- OGAds ---
OGADS_API_KEY=43416|GXVuq8tXEe0RyMb0KEhmmF0utgGKh2z9vQLdSJbld9461413
OGADS_ENDPOINT=https://checkmyapp.space/api/v2

# NOTE: Active provider (adbluemedia | ogads) and per-script offer limits
# (max / min / required leads) are managed from the admin UI → Settings and
# per-script editor. Nothing offer-related needs to live in env.
