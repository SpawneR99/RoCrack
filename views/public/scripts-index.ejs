<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<meta name="description" content="Browse <%= scripts.length %>+ free Roblox scripts for Blox Fruits, Rivals, Fisch, Brookhaven, Grow a Garden & more. All scripts tested, safe & updated daily. Works with Delta Executor mobile & PC.">
<meta name="robots" content="index, follow">
<link rel="canonical" href="/scripts">
<link rel="icon" type="image/png" href="/logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --primary:#00f0ff;--primary-glow:rgba(0,240,255,0.5);--accent:#7c3aed;
    --bg-dark:#0a0a0f;--bg-darker:#050508;--bg-card:rgba(15,15,25,0.9);
    --text-primary:#fff;--text-secondary:#a0a0b5;--text-muted:#5a5a70;
    --border-color:rgba(0,240,255,0.2);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{overflow-x:hidden}
  body{font-family:'Inter',sans-serif;background:var(--bg-darker);color:var(--text-primary);min-height:100vh;overflow-x:hidden}
  .bg-grid{position:fixed;inset:0;background-image:linear-gradient(rgba(0,240,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,240,255,0.03) 1px,transparent 1px);background-size:50px 50px;z-index:0}
  .bg-glow{position:fixed;inset:0;z-index:0;background:radial-gradient(ellipse 80% 50% at 50% 0%,rgba(0,240,255,0.15),transparent 50%),radial-gradient(ellipse 60% 40% at 100% 100%,rgba(124,58,237,0.08),transparent 50%);pointer-events:none}

  .container{position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:2rem 1.5rem;min-height:100vh}
  .header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;padding:1rem 1.5rem;background:var(--bg-card);backdrop-filter:blur(12px);border:1px solid var(--border-color);border-radius:16px}
  .back-btn{display:inline-flex;align-items:center;gap:0.5rem;color:var(--text-secondary);font-size:0.88rem;font-weight:600;letter-spacing:0.05em;padding:0.5rem 1rem;border:1px solid var(--border-color);border-radius:10px;transition:all 0.3s;text-decoration:none}
  .back-btn:hover{color:var(--primary);border-color:var(--primary)}
  .script-count{color:var(--primary);font-size:0.8rem;font-weight:700;letter-spacing:0.1em;padding:0.5rem 1rem;background:rgba(0,240,255,0.1);border:1px solid var(--border-color);border-radius:10px}

  .privacy-notice{background:rgba(239,68,68,0.08);border:2px solid rgba(239,68,68,0.3);border-radius:16px;padding:1.25rem 1.5rem;margin-bottom:2rem;text-align:center}
  .privacy-notice p{color:#fca5a5;font-size:0.88rem;line-height:1.7}
  .privacy-notice strong{color:#ef4444}

  .hero{text-align:center;margin:2.5rem 0}
  .hero-title{font-size:clamp(2rem,5vw,3rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:0.75rem;background:linear-gradient(135deg,#fff 0%,var(--primary) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .hero-subtitle{color:var(--text-secondary);font-size:1.05rem}

  .scripts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;margin-top:2rem}
  .script-card{position:relative;display:block;padding:1.5rem;background:var(--bg-card);backdrop-filter:blur(12px);border:1px solid var(--border-color);border-radius:16px;text-decoration:none;color:var(--text-primary);transition:all 0.3s;overflow:hidden}
  .script-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(0,240,255,0.08),transparent 60%);opacity:0;transition:opacity 0.3s}
  .script-card:hover{transform:translateY(-4px);border-color:rgba(0,240,255,0.5);box-shadow:0 10px 40px rgba(0,240,255,0.15)}
  .script-card:hover::before{opacity:1}
  .script-card-content{position:relative;display:flex;align-items:center;gap:1rem}
  .script-icon{width:60px;height:60px;border-radius:12px;object-fit:cover;flex-shrink:0;background:var(--bg-darker);border:1px solid var(--border-color)}
  .script-info{flex:1;min-width:0}
  .script-name{font-size:1.1rem;font-weight:700;margin-bottom:0.25rem}
  .script-meta{display:flex;align-items:center;gap:0.5rem;font-size:0.78rem;color:var(--text-muted)}
  .status-dot{width:8px;height:8px;border-radius:50%;background:#22c55e;box-shadow:0 0 8px rgba(34,197,94,0.6)}
  .script-status{display:inline-flex;align-items:center;gap:0.35rem;color:#22c55e;font-weight:600;letter-spacing:0.06em}
  .script-arrow{width:32px;height:32px;display:flex;align-items:center;justify-content:center;color:var(--text-muted);transition:all 0.3s}
  .script-card:hover .script-arrow{color:var(--primary);transform:translateX(4px)}
  .script-arrow svg{width:20px;height:20px}

  footer{text-align:center;margin-top:3rem;padding:2rem 0;color:var(--text-muted);font-size:0.85rem}
  footer a{color:var(--primary);text-decoration:none}

  .empty{text-align:center;padding:4rem 1rem;color:var(--text-secondary)}
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="bg-glow"></div>
<div class="container">
  <header class="header">
    <a href="/" class="back-btn">← BACK</a>
    <a href="/" style="display:flex;align-items:center"><img src="/logo.png" alt="RoCrack" style="height:44px;width:auto;filter:drop-shadow(0 0 14px rgba(0,240,255,0.3))"></a>
    <span class="script-count"><%= scripts.length %> SCRIPTS</span>
  </header>

  <div class="privacy-notice">
    <p>⚠ <strong>WE NEVER ASK FOR YOUR PERSONAL DATA.</strong> We only need your <strong>Roblox username</strong> (public info). We will <strong>NEVER</strong> ask for your password, email, or any account credentials.</p>
  </div>

  <div class="hero">
    <h1 class="hero-title">Select Your Script</h1>
    <p class="hero-subtitle">Choose from our collection of premium scripts for popular Roblox games</p>
  </div>

  <% if (scripts.length === 0) { %>
    <div class="empty"><p>No scripts available yet. Check back soon!</p></div>
  <% } else { %>
    <div class="scripts-grid">
      <% scripts.forEach(function(s) { %>
        <a href="/scripts/<%= s.slug %>" class="script-card">
          <div class="script-card-content">
            <img src="<%= s.icon_path %>" alt="<%= s.name %>" class="script-icon" onerror="this.src='/logo.png'">
            <div class="script-info">
              <h3 class="script-name"><%= s.name %></h3>
              <div class="script-meta">
                <span class="script-status"><span class="status-dot"></span>ONLINE</span>
              </div>
            </div>
            <div class="script-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>

  <footer>
    <p>© <%= new Date().getFullYear() %> RoCrack · <a href="/privacy.html">Privacy</a> · <a href="/terms.html">Terms</a></p>
  </footer>
</div>
</body>
</html>
