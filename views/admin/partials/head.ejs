<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow, noarchive">
<meta name="referrer" content="no-referrer">
<title><%= title %> · RoCrack Admin</title>
<link rel="icon" type="image/png" href="/logo.png">
<style>
  :root {
    --bg:#0a0a0f; --bg2:#11111a; --card:#15151f;
    --border:#25252f; --border2:#30303a;
    --text:#f0f0f5; --muted:#8a8aa0; --dim:#5a5a70;
    --primary:#22c55e; --primary-dark:#16a34a;
    --danger:#ef4444; --warn:#f59e0b; --info:#3b82f6;
    --radius:10px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,-apple-system,Segoe UI,Roboto,sans-serif;min-height:100vh}
  a{color:var(--primary);text-decoration:none}
  a:hover{text-decoration:underline}
  .topbar{position:sticky;top:0;z-index:10;background:var(--bg2);border-bottom:1px solid var(--border);padding:0.9rem 1.5rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
  .topbar .brand{display:flex;align-items:center;gap:0.6rem;font-weight:700;font-size:1rem;color:var(--text)}
  .topbar .brand img{height:28px;width:auto}
  .topbar .spacer{flex:1}
  .topbar nav{display:flex;gap:0.25rem;flex-wrap:wrap}
  .topbar nav a{color:var(--muted);padding:0.4rem 0.75rem;border-radius:8px;font-size:0.88rem}
  .topbar nav a:hover{background:var(--card);color:var(--text);text-decoration:none}
  .topbar nav a.active{background:var(--card);color:var(--primary)}
  .topbar form{display:inline}
  .topbar .logout-btn{background:transparent;color:var(--muted);border:1px solid var(--border);padding:0.4rem 0.8rem;border-radius:8px;cursor:pointer;font-size:0.85rem}
  .topbar .logout-btn:hover{border-color:var(--danger);color:var(--danger)}

  .container{max-width:1200px;margin:0 auto;padding:2rem 1.5rem}
  h1{font-size:1.6rem;margin-bottom:1.5rem}
  h1 .sub{color:var(--muted);font-weight:400;font-size:1rem}
  h2{font-size:1.15rem;margin:1.5rem 0 0.8rem;color:var(--text)}
  h3{font-size:1rem;margin:1rem 0 0.5rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.04em;font-weight:600}

  .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;margin-bottom:1.5rem}

  .flash{background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);color:#86efac;padding:0.75rem 1rem;border-radius:8px;margin-bottom:1.25rem}
  .error-box{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;padding:0.75rem 1rem;border-radius:8px;margin-bottom:1rem}

  label{display:block;margin-bottom:0.35rem;color:var(--muted);font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em}
  input[type=text],input[type=number],input[type=password],input[type=url],select,textarea{
    width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:8px;
    color:var(--text);padding:0.7rem 0.85rem;font:inherit;font-size:0.95rem;
    transition:border-color 0.15s;
  }
  input:focus,textarea:focus,select:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(34,197,94,0.15)}
  textarea{min-height:120px;resize:vertical;font-family:inherit}
  textarea.large{min-height:220px}
  input[type=file]{padding:0.5rem;border:1px dashed var(--border);background:var(--bg2);border-radius:8px;color:var(--muted);width:100%;font-size:0.88rem}
  .checkbox-field{display:flex;align-items:center;gap:0.6rem}
  .checkbox-field label{margin:0;text-transform:none;letter-spacing:normal;font-weight:500;color:var(--text)}
  .checkbox-field input[type=checkbox]{width:18px;height:18px;accent-color:var(--primary)}

  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
  .form-row.three{grid-template-columns:1fr 1fr 1fr}
  .form-field{margin-bottom:1rem}
  .form-field .hint{color:var(--dim);font-size:0.78rem;margin-top:0.3rem;letter-spacing:normal;text-transform:none;font-weight:400}
  .form-field .err{color:#fca5a5;font-size:0.82rem;margin-top:0.3rem;letter-spacing:normal;text-transform:none;font-weight:400}

  .btn{display:inline-flex;align-items:center;gap:0.5rem;background:var(--primary);color:#fff;border:none;padding:0.7rem 1.3rem;border-radius:8px;font-size:0.93rem;font-weight:600;cursor:pointer;text-decoration:none;transition:background 0.15s}
  .btn:hover{background:var(--primary-dark);text-decoration:none;color:#fff}
  .btn.secondary{background:var(--bg2);color:var(--text);border:1px solid var(--border)}
  .btn.secondary:hover{background:var(--card);border-color:var(--border2)}
  .btn.danger{background:var(--danger)}
  .btn.danger:hover{background:#dc2626}
  .btn.ghost{background:transparent;color:var(--muted);border:1px solid var(--border)}
  .btn.ghost:hover{color:var(--text);border-color:var(--border2)}
  .btn.sm{padding:0.45rem 0.85rem;font-size:0.82rem}
  .btn.wide{width:100%;justify-content:center}

  table{width:100%;border-collapse:collapse;margin-top:0.5rem}
  th,td{text-align:left;padding:0.75rem 0.9rem;border-bottom:1px solid var(--border)}
  th{color:var(--muted);font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;background:var(--bg2)}
  tr:hover td{background:rgba(255,255,255,0.02)}
  td.icon-cell{width:48px}
  td.icon-cell img{height:32px;width:32px;object-fit:cover;border-radius:6px;border:1px solid var(--border);background:var(--bg2)}

  .badge{display:inline-block;padding:0.2rem 0.55rem;border-radius:6px;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em}
  .badge.legacy{background:rgba(245,158,11,0.15);color:#fbbf24;border:1px solid rgba(245,158,11,0.3)}
  .badge.active{background:rgba(34,197,94,0.15);color:#86efac;border:1px solid rgba(34,197,94,0.3)}
  .badge.inactive{background:rgba(239,68,68,0.1);color:#fca5a5;border:1px solid rgba(239,68,68,0.25)}
  .badge.provider{background:rgba(59,130,246,0.15);color:#93c5fd;border:1px solid rgba(59,130,246,0.3)}

  .actions{display:flex;gap:0.5rem;align-items:center}
  .hub-row{display:grid;grid-template-columns:2fr 1fr auto;gap:0.5rem;margin-bottom:0.5rem;align-items:center}
  .hub-row input{margin:0}
  .hub-row .del{background:transparent;border:1px solid var(--border);color:var(--muted);width:34px;height:34px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.1rem;line-height:1}
  .hub-row .del:hover{border-color:var(--danger);color:var(--danger)}

  .provider-pill{display:inline-flex;align-items:center;gap:0.45rem;padding:0.35rem 0.75rem;border-radius:20px;background:var(--bg2);border:1px solid var(--border);color:var(--muted);font-size:0.82rem}
  .provider-pill .dot{width:8px;height:8px;border-radius:50%;background:var(--primary)}
  .provider-pill strong{color:var(--text);font-weight:600;letter-spacing:0.02em}

  .login-wrap{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1.5rem}
  .login-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:2.5rem;max-width:400px;width:100%}
  .login-card h1{text-align:center;margin-bottom:1.5rem}
  .login-card .brand-small{display:flex;justify-content:center;margin-bottom:1.5rem}
  .login-card .brand-small img{height:48px}

  .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:1.5rem}
  .stat{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.2rem}
  .stat .label{color:var(--muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;font-weight:600}
  .stat .val{font-size:1.6rem;font-weight:700;margin-top:0.4rem;color:var(--text)}

  @media(max-width:700px){
    .form-row,.form-row.three{grid-template-columns:1fr}
    .topbar{padding:0.75rem 1rem}
    .container{padding:1.25rem 1rem}
    th,td{padding:0.5rem 0.5rem;font-size:0.85rem}
  }
</style>
</head>
<body>
